{
  "name": "consumer",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/consumer/src",
  "tags": ["type:app", "scope:backend"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx watch src/main.ts",
        "cwd": "apps/consumer",
        "env": {
          "CONSUMER_PORT": "3002"
        }
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.json --outDir ../../dist/apps/consumer",
        "cwd": "apps/consumer"
      }
    }
  }
}
